rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Artists collection - public read, admin/artist write
    match /artists/{artistId} {
      allow read: if true;
      // Admin can write anything
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];
      // Artists can create/update their own artist document
      allow create: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist' &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist' &&
        resource.data.userId == request.auth.uid;
    }

    // Songs collection - public read, admin/artist write
    match /songs/{songId} {
      allow read: if true;
      // Admin can write anything
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];
      // Artists can create/update/delete their own songs
      allow create: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist' &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist' &&
        resource.data.createdBy == request.auth.uid;
    }

    // Genres collection - public read, admin write
    match /genres/{genreId} {
      allow read: if true;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];
    }

    // Languages collection - public read, admin write
    match /languages/{languageId} {
      allow read: if true;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];
    }

    // Translations collection - public read, authenticated write
    match /translations/{translationId} {
      allow read: if true;
      // Anyone authenticated can create translations
      allow create: if request.auth != null;
      // Users can update/delete their own translations
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      // Artists can update/delete translations for their own songs
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist' &&
        exists(/databases/$(database)/documents/songs/$(resource.data.songId)) &&
        get(/databases/$(database)/documents/songs/$(resource.data.songId)).data.createdBy == request.auth.uid;
      // Admins can do everything
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Translation Votes collection - authenticated read/write
    match /translationVotes/{voteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }

    // Translation Corrections collection - public read, authenticated create, owner/admin update
    match /translationCorrections/{correctionId} {
      allow read: if true;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Annotations collection - public read, authenticated write
    match /annotations/{annotationId} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // Favorites collection - user can only access their own
    match /favorites/{favoriteId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // History collection - user can only access their own
    match /history/{historyId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // Users collection - users can read/write their own, admins can do everything
    match /users/{userId} {
      // Allow user to read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow admins to read all users (use get() to check admin status)
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Allow admins to update any user
      allow update: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Allow anyone to create their own user document (for first-time login)
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Genie Settings collection - public read, admin write
    match /genieSettings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Topics collection - public read, authenticated create, owner/admin edit/delete
    match /topics/{topicId} {
      allow read: if true;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'])
      );
    }

    // Topic Comments collection - public read, authenticated create, owner/admin edit/delete
    match /topicComments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'])
      );
    }

    // Topic Likes collection - authenticated read/write
    match /topicLikes/{likeId} {
      allow read, write: if request.auth != null;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // Comment Likes collection - authenticated read/write
    match /commentLikes/{likeId} {
      allow read, write: if request.auth != null;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // Topic Shares collection - authenticated read/write
    match /topicShares/{shareId} {
      allow read, write: if request.auth != null;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }

    // Forum Categories collection - public read, admin write
    match /forumCategories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Sync Jobs collection - authenticated users can read/write their own, admins can read all
    match /syncJobs/{jobId} {
      // Users can read their own sync jobs
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      // Users can create their own sync jobs
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      // Users can update/delete their own sync jobs, admins can update/delete any
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
  }
}





