# Environment Variables Template
# Copy this file to .env.local for local development
# For production, use .env.production (this will be committed to git)

# Gemini API Key (Required for AI translations)
GEMINI_API_KEY=your_gemini_api_key_here

# Genius API (Optional - for lyric imports)
GENIUS_ACCESS_TOKEN=your_genius_token_here

# LyricFind API (Optional - for lyric imports)
LYRICFIND_API_KEY=your_lyricfind_key_here
LYRICFIND_USERNAME=your_lyricfind_username_here

# Last.fm API (Optional)
LASTFM_API_KEY=your_lastfm_key_here
