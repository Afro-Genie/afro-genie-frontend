# Frontend runtime keys
VITE_API_URL=https://afro-genie-backend-staging-production.up.railway.app/api
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_USE_FUNCTIONS_EMULATOR=false

# Optional integrations (AI keys are backend-only, not exposed to frontend)
GENIUS_ACCESS_TOKEN=your_genius_access_token
LYRICFIND_API_KEY=your_lyricfind_api_key
LYRICFIND_USERNAME=your_lyricfind_username

# Spotify OAuth (PKCE)
# IMPORTANT: As of Nov 2025, Spotify removed http://localhost support.
# For local dev, use http://127.0.0.1:3000 (loopback IP).
# For staging/production, use your HTTPS domain.
# Register ALL redirect URIs in Spotify Developer Dashboard:
#   http://127.0.0.1:3000
#   https://your-production-domain.com
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional script/admin values
FIREBASE_API_KEY=your_firebase_api_key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_secure_password
ADMIN_NAME=Admin User
