{
  "functions": {
    "source": "functions"
  },
"storage": [
    {
      "bucket": "afrogenie.firebasestorage.app",
      "rules": "storage.rules"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

