rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Artist images - public read, authenticated write
    match /artists/{artistId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        resource.size < 5 * 1024 * 1024 && // 5MB limit
        resource.contentType.matches('image/.*');
    }

    // Song images - public read, authenticated write
    match /songs/{songId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        resource.size < 5 * 1024 * 1024 && // 5MB limit
        resource.contentType.matches('image/.*');
    }

    // Genre images - public read, authenticated write
    match /genres/{genreId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        resource.size < 5 * 1024 * 1024 && // 5MB limit
        resource.contentType.matches('image/.*');
    }

    // User profile pictures - users can only access their own
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.uid == userId &&
        resource.size < 2 * 1024 * 1024 && // 2MB limit
        resource.contentType.matches('image/.*');
    }
  }
}


